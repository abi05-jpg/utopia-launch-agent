      "parameters": {
        "jsCode": "const raw =\n  $json.output ||\n  $json.text ||\n  $json.message?.content ||\n  $json.content ||\n  \"\";\n\nlet parsed = {};\n\ntry {\n  parsed = typeof raw === \"string\" ? JSON.parse(raw) : raw;\n} catch (error) {\n  parsed = {};\n}\n\nreturn [\n  {\n    json: {\n      timestamp: new Date().toISOString(),\n\n      meeting_title: parsed.meetingTitle || \"\",\n      meeting_date: parsed.meetingDate || \"\",\n      key_attendee_name: parsed.attendeeName || \"\",\n      key_attendee_email: parsed.attendeeEmail || \"\",\n\n      strongestMoment: parsed.strongestMoment || \"\",\n      lead: parsed.lead || \"\",\n      amplify: parsed.amplify || \"\",\n      unify: parsed.unify || \"\",\n      nurture: parsed.nurture || \"\",\n      convert: parsed.convert || \"\",\n      harvest: parsed.harvest || \"\",\n      linkedinPost: parsed.linkedinPost || \"\",\n      emailSubject: parsed.emailSubject || \"\",\n      emailBody: parsed.emailBody || \"\",\n      pressAngle: parsed.pressAngle || \"\",\n      nextBestAction: parsed.nextBestAction || \"\",\n\n      fullJSON: JSON.stringify(parsed)\n    }\n  }\n];"
      },
